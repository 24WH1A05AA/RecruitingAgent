# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── OpenRouter (required) ────────────────────────────────────────────────────
# Get your free key at https://openrouter.ai/keys
# Used by parse_resume and score_candidate tools.
OPENROUTER_API_KEY=sk-or-v1-...

# ── OpenAI fallback (optional) ───────────────────────────────────────────────
# Used only if OPENROUTER_API_KEY is empty.
OPENAI_API_KEY=sk-...

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=techvest-recruitment-agent

# ── App settings ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_AGENT_ITERATIONS=10

# ── LLM generation parameters ────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
